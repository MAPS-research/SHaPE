# API Keys Configuration
# Copy this file to .env and fill in your API keys

# OpenAI API Key (Required for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (Required for Gemini models)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude API Key (Required for Claude models)
CLAUDE_API_KEY=your_claude_api_key_here

# Together AI API Key (Optional, for open-source models)
TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter API Key (Optional, for OpenRouter models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# EduChat Configuration (Optional, for local EduChat deployment)
EDUCHAT_BASE_URL=http://localhost:8000

# Optional: Model-specific token limits
# GEMINI_MAX_TOKENS=8000
# CLAUDE_MAX_TOKENS=8000
# TOGETHER_MAX_TOKENS=8000
# OPENROUTER_MAX_TOKENS=8000

